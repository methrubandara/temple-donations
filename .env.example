# Client-side admin PIN shown in the browser code (do not use a sensitive value)
# Must match AWS CDK deploy parameter: AdminPin
VITE_ADMIN_PIN=2923

# Optional AWS backend base URL. If set, app reads/writes data to AWS instead of localStorage.
# Example: https://abc123.execute-api.us-east-1.amazonaws.com
VITE_API_BASE_URL=https://3rzyjpa9bl.execute-api.us-east-2.amazonaws.com/

# Server-side secret for AI extraction endpoint (used by Vercel/Netlify serverless functions)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
