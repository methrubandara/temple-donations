# Optional local-only fallback PIN used when no AWS backend URL is configured.
VITE_ADMIN_PIN=2923

# Optional AWS backend base URL. If set, app reads/writes data to AWS instead of localStorage.
# Example: https://abc123.execute-api.us-east-1.amazonaws.com
VITE_API_BASE_URL=

# Server-side secret for AI extraction endpoint (used by Vercel/Netlify serverless functions)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

